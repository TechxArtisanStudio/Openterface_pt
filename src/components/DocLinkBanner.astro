---
interface Props {
  message?: string;
}

const { message = 'A documentação completa para esta seção reside em nosso site de documentos enquanto a migração está em andamento.' } =
  Astro.props;

import { siteConfig } from '../config/site';
---

<div class="border-y border-brand-light bg-brand-light px-4 py-3 text-center md:py-3.5" role="status">
  <p class="text-sm leading-relaxed text-ink">{message}</p>
  <a
    href={siteConfig.legacyUrl}
    class="mt-2 inline-block text-sm font-semibold text-ink underline decoration-primary-dark underline-offset-2 hover:text-primary-dark"
    target="_blank"
    rel="noopener"
  >
    Abrir documentação →
  </a>
</div>
