---
import { docsPath, siteConfig } from '../config/site';
import Logo from './Logo.astro';
import FooterNewsletter from './FooterNewsletter.astro';
---

<footer class="border-t border-gray-200 bg-surface">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3">
      <div>
        <Logo variant="default" class="h-7" />
        <p class="mt-3 text-sm text-muted">Soluções KVM-over-USB ultracompactas para profissionais de TI.</p>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-ink">Produtos</h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/products/keymod/" class="text-muted hover:text-primary-dark">Série KeyMod</a></li>
          <li><a href="/products/kvm-go/" class="text-muted hover:text-primary-dark">Série KVM-GO</a></li>
          <li><a href="/products/minikvm/" class="text-muted hover:text-primary-dark">Mini-KVM</a></li>
          <li><a href="/products/accessories/" class="text-muted hover:text-primary-dark">Acessórios</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-ink">Recursos</h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/videos/" class="text-muted hover:text-primary-dark">Vídeos</a></li>
          <li><a href={docsPath('/faq/')} class="text-muted hover:text-primary-dark" target="_blank" rel="noopener">FAQs</a></li>
          <li><a href={docsPath('/app/overview/')} class="text-muted hover:text-primary-dark" target="_blank" rel="noopener">Apps</a></li>
          <li><a href={docsPath('/support/')} class="text-muted hover:text-primary-dark" target="_blank" rel="noopener">Suporte</a></li>
        </ul>
      </div>
    </div>

    <FooterNewsletter
      title="Newsletter"
      description="Atualizações mensais sobre produtos, firmware e dicas KVM."
      submitLabel="Inscrever-se"
      namePlaceholder="Nome"
      emailPlaceholder="Email *"
      footnote="Cancele quando quiser."
    />

    <div class="mt-8 border-t border-gray-200 pt-6 text-center text-xs text-muted">
      <p>© {new Date().getFullYear()} Openterface. KVM-over-USB de código aberto.</p>
      <p class="mt-1">
        <a href={siteConfig.legacyUrl + '/policy/privacy/'} class="hover:text-primary-dark" target="_blank" rel="noopener">Privacidade</a>
        ·
        <a href={siteConfig.legacyUrl + '/policy/terms-of-service/'} class="hover:text-primary-dark" target="_blank" rel="noopener">Termos</a>
        {siteConfig.analytics.enabled && (
          <>
            ·
            <a href="#" id="cookie-settings" class="hover:text-primary-dark">{siteConfig.analytics.consent.cookieLabel}</a>
          </>
        )}
      </p>
    </div>
  </div>
</footer>
