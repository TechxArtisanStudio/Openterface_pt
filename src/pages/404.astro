---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página Não Encontrada" description="A página que você solicitou não pôde ser encontrada." canonicalPath="/404">
  <section class="flex min-h-[50vh] flex-col items-center justify-center px-4 py-16 text-center">
    <h1 class="text-6xl font-bold text-primary-dark">404</h1>
    <p class="mt-4 text-xl text-muted">Página não encontrada</p>
    <a href="/" class="btn btn-primary mt-8">Voltar para o Início</a>
  </section>
</BaseLayout>
