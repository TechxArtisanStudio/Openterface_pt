---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocLinkBanner from '../../components/DocLinkBanner.astro';
import { docsPath } from '../../config/site';
---

<BaseLayout
  title="Sobre o Openterface"
  description="Saiba mais sobre o Openterface — soluções KVM-over-USB de código aberto construídas pela TechxArtisan."
  ogImageAlt="Soluções KVM-over-USB open source Openterface da TechxArtisan"
  canonicalPath="/about/"
>
  <DocLinkBanner />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-4xl font-bold">Sobre o Openterface</h1>
      <p class="mt-6 text-lg leading-relaxed text-muted">
        O Openterface constrói ferramentas KVM-over-USB ultracompactas e de código aberto para profissionais de TI, desenvolvedores e makers. Do Mini-KVM financiado coletivamente ao KVM-GO em tamanho de chaveiro e à série programável KeyMod, nossa missão é simplificar o controle de computadores headless sem equipamentos volumosos ou redes complexas.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={docsPath('/about/about-us/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Sobre Nós Completo →
        </a>
        <a href={docsPath('/about/compliance/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Conformidade →
        </a>
        <a href={docsPath('/about/community/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Comunidade →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
