---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocLinkBanner from '../components/DocLinkBanner.astro';
import { legacyPath } from '../config/site';
---

<BaseLayout
  title="Vídeos"
  description="Demos de produtos, tutoriais e análises do Openterface no YouTube."
  canonicalPath="/videos/"
>
  <DocLinkBanner message="A grade completa de vídeos filtráveis do YouTube está no site legado até portarmos o pipeline de vídeo." />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h1 class="text-4xl font-bold">Vídeos</h1>
      <p class="mt-4 text-lg text-muted">
        Assista a demonstrações de produtos, guias de configuração e análises da comunidade para os produtos KVM e KeyMod do Openterface.
      </p>
      <a href={legacyPath('/videos/')} class="btn btn-primary mt-8" target="_blank" rel="noopener">
        Navegar por todos os vídeos →
      </a>
    </div>
  </section>
</BaseLayout>
