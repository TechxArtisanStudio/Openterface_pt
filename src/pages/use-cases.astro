---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocLinkBanner from '../components/DocLinkBanner.astro';
import { legacyPath } from '../config/site';
---

<BaseLayout
  title="Casos de Uso"
  description="Casos de uso reais para os produtos KVM-over-USB do Openterface."
  canonicalPath="/use-cases/"
>
  <DocLinkBanner />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-4xl font-bold">Casos de Uso</h1>
      <p class="mt-4 text-lg text-muted">
        As ferramentas Openterface brilham sempre que você precisa controlar um computador headless ou de difícil acesso sem um monitor e teclado dedicados.
      </p>
      <ul class="mt-8 space-y-4">
        {
          [
            'Vistorias em data centers e colocation',
            'Administração de homelab e NAS',
            'Inicialização de SBC e dispositivos embarcados',
            'Manutenção de quiosques e sinalização digital',
            'TI de campo e consultoria',
          ].map((item) => (
            <li class="card">{item}</li>
          ))
        }
      </ul>
      <a href={legacyPath('/use-cases/')} class="btn btn-secondary mt-8" target="_blank" rel="noopener">
        Ver galeria completa de casos de uso →
      </a>
    </div>
  </section>
</BaseLayout>
